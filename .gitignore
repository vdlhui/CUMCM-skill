# === CUMCM-skill .gitignore ===

# 运行时输出（每次建模都会生成，不应提交）
paper_output/

# Python 缓存
__pycache__/
*.pyc
*.pyo
*.egg-info/

# 用户赛题文件
problem_files/
cleaned_problem.txt
scan_report.md

# LaTeX 编译临时文件
*.aux
*.out
*.toc
*.log
*.synctex.gz
*.fls
*.fdb_latexmk

# IDE / 编辑器
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# 操作系统
Desktop.ini
